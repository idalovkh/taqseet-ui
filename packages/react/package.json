{
  "name": "@idalovkh/taqseet-ui-react",
  "version": "0.1.5",
  "description": "React UI components for Taqseet design system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idalovkh/taqseet-ui.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
