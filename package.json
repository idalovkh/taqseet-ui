{
  "name": "taqseet-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared design system for Taqseet applications",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "storybook": "npm run storybook -w @taqseet-ui/react",
    "build-storybook": "npm run build-storybook -w @taqseet-ui/react",
    "test:visual": "npm run test:visual -w @taqseet-ui/react"
  },
  "engines": {
    "node": ">=20"
  }
}
